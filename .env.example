# Database (sync psycopg driver)
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/userdata

# JWT
JWT_SECRET=請改成隨機長字串
JWT_EXPIRE_MINUTES=1440

# CORS: comma-separated origins, or * for all
ALLOWED_ORIGINS=*

# App
APP_PORT=8100

# Postgres (used by docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=userdata
