# Database (sync psycopg driver)
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/userdata

# JWT
JWT_SECRET=請改成隨機長字串
JWT_EXPIRE_MINUTES=1440

# CORS: comma-separated origins, or * for all
ALLOWED_ORIGINS=*

# Ingestion: shared secret the screener (stock_market run_intraday) sends in the
# X-Ingest-Token header when POSTing daily screening snapshots. Empty = disabled.
INGEST_TOKEN=請改成隨機長字串

# App
APP_PORT=8100

# Postgres (used by docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=userdata
